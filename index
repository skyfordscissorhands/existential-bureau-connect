<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!--  PAGE TITLE (browser tab)-->
  <title>NameDropR</title>

  <!-- APP ICON + NAME -->
  <link rel="apple-touch-icon" sizes="180x180" href="./AI-icon.png">
  <link rel="icon" type="image/png" sizes="32x32" href="./AI-icon.png">

  <meta name="apple-mobile-web-app-title" content="NameDropR">
  <meta name="apple-mobile-web-app-capable" content="yes">

  <!--  GOOGLE FONT -->
  <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">

  <!-- LINK PREVIEW (OG TAGS)-->

  <!-- Title (bold headline in preview) -->
  <meta property="og:title" content="Soil & Groundwater Professionals" />

  <!-- Description (small text under title) -->
  <meta property="og:description" content="Tap to save contact info and connect instantly." />

  <!-- Preview Image -->
  <meta property="og:image" content="https://skyfordscissorhands.github.io/connect/Phone-preview.jpg" />

  <!-- URL (base page) -->
  <meta property="og:url" content="https://skyfordscissorhands.github.io/connect/connect-scalable.html" />

  <!-- Makes image large format -->
  <meta name="twitter:card" content="summary_large_image" />
  
  <style>

  * {
  box-sizing: border-box;
}
    
  :root { 
    --ai-blue:#0073E5; 
    --ai-green:#22C55E; 
    --ai-light:#E1F1FD; 
    --ai-ink:#15182F; 
  }

  body {
    margin:0; 
    font-family:"Open Sans",sans-serif; 
    color:var(--ai-ink);
    background:#ffffff; 
    min-height:100vh; 
    display:flex; 
    align-items:flex-start; 
    justify-content:center; 
  }

  .card { 
    background:#E1F1FD;
    border-radius:0; 
    box-shadow:0 12px 24px rgba(0,115,229,.2);
    padding:40px 36px 30px; 
    text-align:center; 
    width:100%; 
    max-width:420px;
    position:relative;
    overflow:hidden;
    min-height:100vh;
    max-height:640px;

  }

  .card-header{
    position:relative;
    height:clamp(260px, 32vh, 340px);
    margin:-40px -36px 0 -36px;
    background:url("soil-card-background.png") center -70px / cover no-repeat;
  }
    
  .card-logo{
    position:absolute;
    top:20px;
    left:50%;
    transform:translateX(-50%);
    width:340px;
    z-index:4;
  }

  .employee-photo{
    width: clamp(180px, 20vw, 200px);
    height: clamp(180px, 20vw, 200px);
    object-fit:cover;
    object-position:center 20%;
    border-radius:20px;
    margin:clamp(-150px, -18vh, -130px) auto 10px;
    display:block;
    position:relative;
    z-index:5;
    border:6px solid #fff;
    box-shadow:0 16px 40px rgba(0,0,0,0.25);
  }

.employee-name{
  font-size:30px;
  font-weight:600;
  margin-bottom:10px;
}  

.employee-title{
  font-size:15px;
  opacity:.8;
  margin-bottom:4px;
}

.employee-email{
  font-size:14px;
  opacity:.7;
  margin-bottom:10px;
}

.employee-phone{
  font-size:14px;
  opacity:.75;
  margin-bottom:4px;
}
    
.employee-qr{
  width:85px;
  margin:20px auto 5px;
  display:block;
}

.qr-note{
  font-size:12px;
  opacity:.6;
}
    
  /* Step containers */
  #shareStep, 
  #connectForm {
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    width:100%;
  }

  #connectForm.hidden {
    display: none;
  }
  #connectForm .employee-name{
    font-size:inherit;
    font-weight:600;
}
  #connectForm input{
    background:#F8FBFF;
    border:1px solid rgba(0,115,229,.15);
}

/* FORM CARD (new) */
.form-card{
  position:relative;
  z-index:6;
  
  background:#ffffff;
  border-radius:18px;
  padding:24px;
  
  width:100%;
  max-width:340px;
  
  margin:-130px auto 0;
  
  box-shadow:0 10px 28px rgba(0,0,0,0.08);

  display:flex;
  flex-direction:column;
  align-items:center;
}

/* center inputs inside the form card */
.form-card input,
.form-card button{
  width:100%;
  max-width:280px;
}

  h1, h2 {
    color: var(--ai-blue);
    margin: 0 0 10px;
  }

  p { margin:0 0 20px; }

  input, button {
    width:100%; 
    padding:12px; 
    margin:8px 0; 
    border-radius:10px; 
    font-family:"Open Sans";
  }

/* Highlights active field for better UX */
  input:focus {
    outline: none; /* removes default browser outline */
    border: 1px solid #0073E5; /* AI blue border */
    box-shadow: 0 0 0 2px rgba(0,115,229,0.15); /* soft glow */
  }
    
  button {
    background:var(--ai-blue); 
    color:#fff; 
    border:none; 
    font-weight:600; 
    cursor:pointer; 
    transition:.2s;
    margin-top:16px;
    padding:14px;
    font-size:15px;
  }

  button:hover {
    background:var(--ai-green);
  }

  /* Smooth fade animation for step switch */
  .fade {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .fade.show {
    opacity: 1;
  }

  @media (min-width: 768px) {

  body{
    align-items:center;
    padding:40px;
  }

  .card{
    min-height:640px;
    max-height:720px;
    border-radius:24px;
    overflow:hidden;
  }

  .employee-photo{
    margin:-180px auto 12px;
  }
}
</style>

</head>
<body>
  
  <main class="card">
    <div class="card-header">
        <img class="card-logo" src="ai-light-all-logos.svg" alt="Associated Industries Logos">
    </div>
    
    <!-- Step 1: Share employee’s Info first -->
    <div id="shareStep">
   
    <img id="employeePhoto" class="employee-photo"
     src=""
     alt="Employee Photo">   

    <p style="font-size:12px; letter-spacing:1px; opacity:.6; margin-bottom:6px;">
      CONNECT WITH
    </p>

      <h1 class="employee-name">Loading...</h1>

      <p class="employee-title" id="employeeTitle"></p>

      <p class="employee-email" id="employeeEmail"></p>

      <p class="employee-phone" id="employeePhone"></p>                                              
      
      <button id="saveEmployee">Save Contact</button>
      
      <img id="employeeQR"
         src=""
         alt="QR Code"
         style="width:85px;height:85px;margin:12px auto 4px;display:block;">

      <p style="font-size:11px; opacity:.6; margin:0;">
          Scan to connect
      </p>
    </div>

    <!-- Step 2: Collect visitor info (emails Robert) -->
    <form id="connectForm" class="hidden" action="https://eoz21saxgb2b1vg.m.pipedream.net" method="POST">

    <div class="form-card">
      
      <h2>You're connected</h2>
      <p style="margin-bottom:18px;">
        Share your info so <strong><span class="employee-name"></span></strong> can follow up directly.
      </p>
      <input type="hidden" name="_subject" id="subjectField">
      <input type="hidden" name="slug" id="slugField">
      <input type="text" name="name" placeholder="Your Name" required>
      <input type="email" name="email" placeholder="Your Email" required>
      <input type="tel" name="phone" placeholder="Your Phone" required>
      <input type="text" name="company" placeholder="Company (optional)">
      <button type="submit">Share My Info</button>

      <!-- Skip option -->
      <p style="margin-top:12px; font-size:12px; opacity:.6;">
        <a href="#" id="skipForm" style="color:inherit; text-decoration:underline;">
          Skip this step
        </a>
    </p>
     </div>
      
    </form>
 </main>

 <script>

// Get slug from URL
const urlParams = new URLSearchParams(window.location.search);
const slug = urlParams.get("slug");
// Show quick name from slug
if (slug) {
  const quickName = slug
    .split("-")
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");

  document.querySelectorAll(".employee-name, .employee-button-name").forEach(el => {
    el.textContent = quickName;
  });
}

// Load photo instantly from slug
const photo = document.getElementById("employeePhoto");
if (photo && slug) {
  photo.src = `employee-photos/${slug}.jpg`;
}
   
// Create QR code for this employee page
const qr = document.getElementById("employeeQR");

if (qr && slug) {
  const url = `https://skyfordscissorhands.github.io/connect/connect-scalable.html?slug=${slug}`;
  qr.src = `https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=${encodeURIComponent(url)}`;
}   

let employeeName = "Employee Name";
let vcfFile = "default-employee.vcf";

const saveBtn = document.getElementById("saveEmployee");
const shareStep = document.getElementById("shareStep");
const formEl = document.getElementById("connectForm");

// Disable button until employee loads
saveBtn.disabled = true;

async function loadEmployee() {
  if (!slug) {
    saveBtn.disabled = false;
    return;
  }

  const res = await fetch(`https://eosi1gbo0ej0dm9.m.pipedream.net?slug=${encodeURIComponent(slug)}`);
  const data = await res.json();

  employeeName = data.full_name || "Employee Name";
  vcfFile = data.vcf_download_link || "default-employee.vcf";

  document.getElementById("employeeTitle").textContent = data.title || "";
  document.getElementById("employeeEmail").textContent = data.email || "";
  document.getElementById("employeePhone").textContent = data.phone || "";

  const slugField = document.getElementById("slugField");
  if (slugField) slugField.value = slug;

  // Update name on page
  document.querySelectorAll(".employee-name, .employee-button-name").forEach(el => {
    el.textContent = employeeName;
  });

  // Update email subject
  const subjectField = document.getElementById("subjectField");
  if (subjectField) {
    subjectField.value = `New contact for ${employeeName}`;
  }

  // Enable button once ready
  saveBtn.disabled = false;
}
  
loadEmployee();

// Step 1 → Download employee VCF → Reveal form
saveBtn.addEventListener("click", () => {
  window.location.href = vcfFile;

  // Show confirmation first
  shareStep.innerHTML = `
    <div style="text-align:center; padding:40px 20px;">
      <h2 style="color:#0073E5;">Contact Saved</h2>
     <p style="margin-top:10px;">
      ${employeeName}'s info is now in your phone.
    </p>
    <p style="font-size:13px; opacity:.7; margin-top:8px;">
      Want them to have yours too?
    </p>
  </div>
`;

  setTimeout(() => {
    shareStep.style.display = "none";
    formEl.style.display = "flex";
  }, 2500);
});

// Step 2 → Submit form → Show thank-you → Redirect
formEl.addEventListener("submit", (e) => {
  e.preventDefault();
  const formData = new FormData(formEl);

  fetch(formEl.action, {
    method: "POST",
    body: formData,
    headers: { Accept: "application/json" }
  })
  .then(() => {
    formEl.innerHTML = `
      <div style="text-align:center;">
        <h2>Thanks for connecting!</h2>
        <p>Your info has been sent to ${employeeName}.</p>
      </div>`;
    setTimeout(() => {
      window.location.href = "https://associated-industries.com/";
    }, 2000);
  })
  .catch(() => {
    formEl.innerHTML = "<p>Something went wrong. Please try again.</p>";
  });
});

// Skip Button (Optional Step)

const skipBtn = document.getElementById("skipForm");

if (skipBtn) {
  skipBtn.addEventListener("click", (e) => {
    e.preventDefault();

    // Redirect user if they choose to skip
    window.location.href = "https://associated-industries.com/";
  });
}   
   
</script>
</body>
</html>
